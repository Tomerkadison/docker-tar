# Docker Tar frontend configuration.
#
# Copy this file to `.env.local` and adjust the values to run against a local
# backend. Create React App only reads variables prefixed with REACT_APP_, and
# you must restart `npm start` after changing them.
#
# Leaving a value unset falls back to the production host (see src/config.js).

# App backend (FastAPI, served behind nginx in production).
# Handles /install and /report/success.
REACT_APP_BACKEND_URL=https://dockertar.zapto.org

# Docker Hub proxy base. In production this is the same nginx host that proxies
# /dockerhub/* to Docker Hub's APIs.
REACT_APP_DOCKERHUB_PROXY_URL=https://dockertar.zapto.org

# Cloudflare Turnstile site key used on the verify page.
REACT_APP_TURNSTILE_SITE_KEY=0x4AAAAAAB02nGeNdVYltnlB

# --- Example local setup (uncomment / edit) ---
# REACT_APP_BACKEND_URL=http://localhost:8080
# REACT_APP_DOCKERHUB_PROXY_URL=http://localhost:8080
